# Supabase — Project Settings → API
# The anon key is public by design: access is enforced server-side by Row Level Security.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# The values below are NOT used by the frontend. They are set as Edge Function
# secrets (supabase secrets set KEY=value) and must never reach the browser.
#
#   STRIPE_SECRET_KEY        Stripe → Developers → API keys (test mode)
#   STRIPE_WEBHOOK_SECRET    Stripe → Developers → Webhooks → signing secret
#   RESEND_API_KEY           Resend → API keys
#   ALLOWED_ORIGINS          Comma-separated origins allowed to call the functions
# ─────────────────────────────────────────────────────────────────────────────
